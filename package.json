{
  "name": "@aws-access-bridge/monorepo",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-spa-shell-stub.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm --filter @aws-access-bridge/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "prettier": "prettier --write .",
    "lint": "eslint --ext .ts,.tsx --fix .",
    "deploy": "pnpm run build && wrangler deploy --dry-run && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^17.5.0",
    "jsonc-parser": "^3.3.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.85.0"
  },
  "packageManager": "pnpm@10.12.4"
}
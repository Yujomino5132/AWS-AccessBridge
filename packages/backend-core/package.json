{
  "name": "@aws-access-bridge/backend-core",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./base": "./src/base/index.ts",
    "./base/*": "./src/base/*.ts",
    "./constants": "./src/constants/index.ts",
    "./constants/*": "./src/constants/*.ts",
    "./crypto": "./src/crypto/index.ts",
    "./crypto/*": "./src/crypto/*.ts",
    "./dao": "./src/dao/index.ts",
    "./dao/*": "./src/dao/*.ts",
    "./error": "./src/error/index.ts",
    "./error/*": "./src/error/*.ts",
    "./model": "./src/model/index.ts",
    "./model/*": "./src/model/*.ts",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.27",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
